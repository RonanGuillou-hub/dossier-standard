# Copier ce fichier en .env (jamais commité — voir .gitignore) et
# renseigner les vraies valeurs pour le développement local.
# En CI/production, ces variables sont injectées directement par la
# plateforme (GitHub Secrets, HuggingFace Jobs) — ce fichier ne sert
# qu'en local.

# --- HuggingFace ---
HF_TOKEN=
HF_MODEL_REPO=

# --- MLflow ---
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=

# --- AWS S3 (persistance meteo.csv / dataset_clean.csv) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
